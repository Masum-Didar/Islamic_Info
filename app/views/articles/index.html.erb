<h2>Welcome to our islamic info page</h2>

<% @articles.each do |article| %>
<div class="card">
  <div class="card-header">
    <a href="/articles/<%=article.id %>">
      <%= article.title %>
    </a>

  </div>
  <div class="card-body">
      <%= article.body %>
  </div>
  <div class="card-body">
    <%= article.category %>
  </div>
</div><br>
<% end %>
<%= link_to "New Article", new_article_path %>
