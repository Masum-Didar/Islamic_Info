<h4> <%= @article.title %></h4>
<h6> <%= @article.body %></h6>
<h6> <%= @article.category %></h6>

<ul>
  <li><%= link_to "Edit", edit_article_path(@article) %></li>
  <li><%= link_to "Delete", article_path(@article),
                  data: {
                    turbo_method: :delete,
                    turbo_confirm: "Are you sure ?"
                  } %></li>
</ul>